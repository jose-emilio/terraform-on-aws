# Backend config para Lab27 en AWS real.
# Usa el bucket creado en el Lab02 (terraform-state-labs-<ACCOUNT_ID>).
# Usalo asi:
#   terraform init -backend-config=aws.s3.tfbackend -backend-config="bucket=terraform-state-labs-<ACCOUNT_ID>"
key            = "lab27/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
use_lockfile   = true
