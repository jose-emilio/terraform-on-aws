# Backend config para Lab25 en AWS real.
# Usa el bucket creado en el Lab02 (terraform-state-labs-<ACCOUNT_ID>).
# Para despliegue:
#   terraform init -backend-config=aws.s3.tfbackend -backend-config="bucket=terraform-state-labs-<ACCOUNT_ID>"
# Para tests:
#   terraform init -backend=false
#   terraform test
key            = "lab25/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
use_lockfile   = true
